// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (Supabase Auth) ----------
// Auth itself (password hashing, sessions, tokens) lives in Supabase's own
// `auth.users` table, which Prisma doesn't manage. This User model is the
// app-data profile row; its id is set explicitly to match the corresponding
// auth.users.id at signup — no FK is declared since Prisma can't model a
// cross-schema reference, but the values are kept in sync by convention.

model User {
  id    String  @id @db.Uuid
  name  String?
  email String  @unique
  image String?

  xp             Int       @default(0)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress     Progress[]
  achievements UserAchievement[]
  quizAttempts QuizAttempt[]
}

// ---------- Curriculum ----------

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum Skill {
  READING
  WRITING
  LISTENING
  SPEAKING
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  SENTENCE_ORDER
  DICTATION
  WRITING_PROMPT
  SPEAKING_PROMPT
  MATCHING
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum QuizKind {
  UNIT_QUIZ
  LEVEL_ASSESSMENT
}

model Level {
  id          String    @id @default(cuid())
  code        CefrLevel @unique
  title       String
  description String?
  order       Int       @unique

  units       Unit[]
  assessments Quiz[]    @relation("LevelAssessments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id          String  @id @default(cuid())
  levelId     String
  title       String
  description String?
  order       Int

  level   Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([levelId, order])
}

model Lesson {
  id      String @id @default(cuid())
  unitId  String
  title   String
  skill   Skill
  order   Int
  content Json? // structured lesson body (passages, prompts, audio refs, etc.)

  unit       Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises  Exercise[]
  vocabulary Vocabulary[]
  audio      Audio[]
  progress   Progress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([unitId, order])
}

model Exercise {
  id       String       @id @default(cuid())
  lessonId String
  type     ExerciseType
  order    Int
  prompt   String
  data     Json // options, correct answer(s), matching pairs, etc.

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lessonId, order])
}

model Vocabulary {
  id              String  @id @default(cuid())
  lessonId        String?
  word            String
  translation     String
  exampleSentence String?
  audioUrl        String?

  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Audio {
  id              String  @id @default(cuid())
  lessonId        String?
  url             String
  transcript      String?
  durationSeconds Int?

  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ---------- Progress & Assessment ----------

model Progress {
  id          String         @id @default(cuid())
  userId      String         @db.Uuid
  lessonId    String
  status      ProgressStatus @default(NOT_STARTED)
  score       Float?
  attempts    Int            @default(0)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Quiz {
  id      String   @id @default(cuid())
  kind    QuizKind
  title   String
  unitId  String?
  levelId String?

  unit      Unit?         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  level     Level?        @relation("LevelAssessments", fields: [levelId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizQuestion {
  id      String @id @default(cuid())
  quizId  String
  order   Int
  prompt  String
  data    Json // options + correct answer

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String   @db.Uuid
  score       Float
  answers     Json
  completedAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Gamification ----------

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  title       String
  description String?
  icon        String?

  users UserAchievement[]

  createdAt DateTime @default(now())
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @db.Uuid
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}
